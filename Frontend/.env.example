# Deceptron SMTP Email Configuration
# ────────────────────────────────
# Using Gmail: enable 2FA → https://myaccount.google.com/apppasswords
# Generate a 16-char App Password for "Mail" and paste it below.
#
# Other providers: change SMTP_HOST / SMTP_PORT accordingly.
# ────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
